{
  "name": "agentdock-api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create agentdock",
    "db:migrate": "wrangler d1 execute agentdock --file=./schema.sql",
    "db:migrate:local": "wrangler d1 execute agentdock --local --file=./schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.22.0"
  }
}
