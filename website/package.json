{
  "name": "website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NEXT_TELEMETRY_DISABLED=1 next dev",
    "dev:test": "NEXT_TELEMETRY_DISABLED=1 next dev --hostname 127.0.0.1 --port 3000",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build",
    "start": "NEXT_TELEMETRY_DISABLED=1 next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build",
    "test:mobile:browser": "node scripts/mobile-regression.mjs",
    "test:mobile": "start-server-and-test dev:test http-get://127.0.0.1:3000 test:mobile:browser",
    "test:release": "node scripts/release-regression.mjs",
    "capture:reference": "node scripts/capture-vokie-reference.mjs",
    "capture:local:browser": "node scripts/capture-local.mjs",
    "capture:local": "start-server-and-test dev:test http-get://127.0.0.1:3000 capture:local:browser",
    "copy:site": "node scripts/export-to-site.mjs",
    "export:site": "npm run build && npm run copy:site"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.1",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.185.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "puppeteer-core": "^25.3.0",
    "start-server-and-test": "^3.0.11",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
